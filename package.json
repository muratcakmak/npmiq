{
  "name": "depiq",
  "version": "1.0.0",
  "description": "CLI and MCP server for discovering and comparing npm packages. Scores candidates using downloads, GitHub health, Reddit signal, and State of JS retention.",
  "type": "module",
  "bin": {
    "depiq": "./bin/run.js",
    "depiq-mcp": "./bin/mcp.js"
  },
  "main": "./dist/cli/index.js",
  "types": "./dist/cli/index.d.ts",
  "files": [
    "dist",
    "bin"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/cli/index.ts",
    "dev:mcp": "tsx src/mcp/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "depiq",
    "npm",
    "package",
    "picker",
    "compare",
    "cli",
    "mcp",
    "agent",
    "dependency"
  ],
  "author": "Oguzhan Cakmak (github.com/muratcakmak)",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.3",
    "commander": "^11.1.0",
    "dotenv": "^16.4.5",
    "ora": "^8.0.1",
    "p-limit": "^5.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  }
}
